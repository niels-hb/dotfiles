{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "grep": "allow",
    "websearch": "allow",
    "todowrite": "allow",
    "explore": "allow",
    "glob": "allow"
  }
}
